# GeoGuessr Dashboard — Docker Configuration
#
# Copy this to .env and modify as needed:
#   cp .env.example .env
#
# These values are used by docker-compose.yml and geoguessr_dashboard.py.

# --- PostgreSQL ---
PG_IMAGE=postgres:16-alpine
PG_CONTAINER=geoguessr-postgres
PG_USER=geoguessr
PG_PASSWORD=geoguessr
PG_DB=geoguessr
PG_PORT=5432
PG_SCHEMA=geoguessr

# --- Grafana ---
GRAFANA_IMAGE=grafana/grafana:11.4.0
GRAFANA_CONTAINER=geoguessr-grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=geoguessr
GRAFANA_PORT=3000
